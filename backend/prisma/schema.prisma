generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  studyType    String?
  createdAt    DateTime @default(now())
  sessions     Session[]
}


model Session {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  duration     Int
  breakTime    Int 
  starttime    DateTime 
  endtime      DateTime 
  progress     Int 
  afterFeeling String
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
}

