{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler", //bundles für vite
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vite/client"], //für zB css import 
    
    "jsx": "react-jsx", //für React

    "strict": true, //TypÜberprüfung
    "noImplicitAny": true, //siehe M2
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
  },
  "include": ["src", "App.tsx", "samples/M2/Login.tsx", "samples/M2/login.ts", "samples/M2/dashboardv2.tsx"],
  "exclude": ["node_modules", "dist"]
}